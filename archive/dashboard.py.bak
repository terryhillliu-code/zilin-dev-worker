#!/usr/bin/env python3
import os, sys, subprocess, json, time
from datetime import datetime

def get_output(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True).strip()
    except Exception:
        return "N/A"

def main():
    print(f"\033[1;36m=== 🧠 知微系统实时全景看板 (v6.7.1) ===\033[0m")
    print(f"当前时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    
    # 1. 物理磁盘监控
    disk = get_output("df -h / | awk 'NR==2 {print $4}'")
    disk_cap = get_output("df -h / | awk 'NR==2 {print $5}'")
    print(f"\n📂 \033[1;33m磁盘水位\033[0m: 可用 \033[1;32m{disk}\033[0m ({disk_cap}) | [安全阈值: > 10GB]")
    
    # 2. 向量化生产链 (Limb)
    task_id = get_output("sqlite3 /Users/liufang/zhiwei-dev/tasks.db 'SELECT id FROM tasks ORDER BY id DESC LIMIT 1'")
    output_dir = "/Users/liufang/zhiwei-dev/output_verified/"
    json_count = get_output(f"ls -1 {output_dir}/*.json 2>/dev/null | wc -l")
    worker_ps = get_output("ps aux | grep -i 'worker.py' | grep -v grep")
    status = "🟢 运行中" if worker_ps != "N/A" else "🔴 已停止 (待命)"
    
    print(f"⚙️  \033[1;33m摄取产出\033[0m: 任务 #\033[1;32m{task_id}\033[0m | {status} | 物理产出: \033[1;32m{json_count}\033[0m/1882")
    
    # 3. 智立方链路 (Brain)
    rag_ps = get_output("ps aux | grep -i 'main.py server' | grep -v grep")
    vite_ps = get_output("ps aux | grep -i 'vite' | grep -v grep || ls -la node_modules/vite")
    gateway_stat = get_output("curl -Is http://localhost:18789/health | head -n 1")
    
    print(f"🚀 \033[1;33m核心服务\033[0m:")
    print(f"   - RAG 后端 (8001): {'✅ Online' if rag_ps != 'N/A' else '❌ Offline'}")
    print(f"   - 前端平台 (5173): {'✅ Online' if '200' in get_output('curl -Is http://localhost:5173 | head -n 1') else '❌ Offline'}")
    print(f"   - 寻址网关 (18789): {gateway_stat if gateway_stat != 'N/A' else '⚠️  Time-out'}")

    # 4. 实时搜索探测 (Proof)
    print(f"\n🔍 \033[1;33m最近入库发现\033[0m:")
    search_hit = get_output("/Users/liufang/zhiwei-bot/venv/bin/python3 /Users/liufang/zhiwei-rag/main.py search 'Visual Saliency' --limit 1 | grep '来源:'")
    print(f"   {search_hit if search_hit != 'N/A' else '⌛ 正在等待 RAG 增量刷新...'}")

    print(f"\n\033[1;30m指令提示: zw-log (看详情) | zw-how (看进度) | zw-shell (看内部)\033[0m")

if __name__ == '__main__':
    main()
# Optimized Pipeline v57 Verification
