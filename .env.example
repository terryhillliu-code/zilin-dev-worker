# 知微系统环境配置文件示例 (v33.0)
# 请复制此文件为 .env 并填写实际值

# --- 飞书机器人配置 (ws_client.py) ---
FEISHU_APP_ID=您的_APP_ID
FEISHU_APP_SECRET=您的_APP_SECRET
FEISHU_WEBHOOK_URL=可选_用于备选通知
FEISHU_USER_ID=您的_飞书用户ID_用于接收通知

# --- 知识库与 Embedding 配置 (knowledge_client.py) ---
EMBEDDING_API_KEY=您的_DashScope_API_KEY
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 任务执行环境配置 (worker.py / supervisor_daemon.py) ---
ANTHROPIC_AUTH_TOKEN=您的_Claude_API_KEY
ZHIWEI_TASK_STORAGE_PATH=~/zhiwei-ops/tasks.db
KLIB_DB_PATH=~/Library/klib.db
KLIB_FTS_PATH=~/Library/klib_fts.db
CHROMADB_PATH=~/Library/chroma_db

# --- 系统路径控制 ---
WATCH_DIR=~/zhiwei-ops/plans/incoming
STATE_DIR=~/zhiwei-ops
WORKTREE_BASE=~/zhiwei-ops/worktrees
